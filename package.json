{
  "name": "ng-ws-stomp-nodejs",
  "version": "1.0.0",
  "description": "Angular frontend with Node.js WebSocket server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "server": "node server.js",
    "server:watch": "nodemon server.js",
    "dev:all": "npm run dev & npm --prefix ws-app start",
    "dev:backend": "nodemon server.js",
    "dev:frontend": "npm --prefix ws-app start",
    "test": "npm --prefix ws-app test",
    "test:ci": "npm --prefix ws-app run test:ci"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "stomp-broker-js": "^1.3.0",
    "websocket": "^1.0.35"
  },
  "devDependencies": {
    "@types/jasmine": "^6.0.0",
    "nodemon": "^3.0.2"
  }
}
